# Smolit Assistant — kuratiertes Minimum-Env (PR 29).
# Alle Variablen sind OPTIONAL mit sinnvollen Defaults. Leerer Wert =
# Feature bleibt inert (honest `unavailable` / `BackendUnsupported`).
# Vollständige Gruppen + Troubleshooting: docs/SETUP.md.
# Keine Secrets hier. cloud_http-API-Keys landen NICHT in .env.

# ------------------------------------------------------------------
# Core / ABrain
# ------------------------------------------------------------------
ABRAIN_CMD=abrain
LOG_LEVEL=info
SMOLIT_IPC_ENABLED=true
# Nur Loopback verwenden — Smolit bindet nie extern.
SMOLIT_IPC_BIND=127.0.0.1:8787

# ------------------------------------------------------------------
# Audio — TTS / STT command-Kinds
# ------------------------------------------------------------------
# Leere Commands → Feature bleibt available=false (ehrlich), kein Crash.
SMOLIT_TTS_ENABLED=true
SMOLIT_TTS_CMD=
SMOLIT_TTS_TIMEOUT_SECONDS=20
SMOLIT_STT_ENABLED=true
SMOLIT_STT_CMD=
SMOLIT_STT_TIMEOUT_SECONDS=20
SMOLIT_AUDIO_AUTO_SPEAK=true

# STT-Provider-Chain (PR 13). Komma-separiert. Default: ["command"].
# Whitelist seit PR 27: command, whisper_cpp.
# Beispiel Fallback-Reihenfolge:
#   SMOLIT_STT_PROVIDER_CHAIN=whisper_cpp,command
SMOLIT_STT_PROVIDER_CHAIN=command
# TTS-Provider-Chain. Komma-separiert. Default: ["command"].
# Whitelist seit PR 34: command, piper.
# Beispiel Fallback-Reihenfolge:
#   SMOLIT_TTS_PROVIDER_CHAIN=piper,command
SMOLIT_TTS_PROVIDER_CHAIN=command

# whisper.cpp-Kind (PR 27). Env-only — kein Runtime-Editor in der
# Settings-Shell. Nur wirksam, wenn whisper_cpp in der STT-Chain
# steht. Kein Modell-Manager; Binary + Modell orchestriert der Nutzer.
SMOLIT_STT_WHISPER_CPP_CMD=

# piper-Kind (PR 34). Env-only — kein Runtime-Editor in der
# Settings-Shell. Nur wirksam, wenn piper in der TTS-Chain steht.
# Kein Modell-Manager; Binary + Stimme/Modell orchestriert der
# Nutzer. Beispiel:
#   SMOLIT_TTS_PIPER_CMD="piper --model /opt/piper/de-thorsten-low.onnx --output-raw"
SMOLIT_TTS_PIPER_CMD=

# ------------------------------------------------------------------
# Text-Provider-Chain
# ------------------------------------------------------------------
# Default ["abrain"]. Whitelist: abrain, llamafile_local, local_http,
# cloud_http. cloud_http ist NICHT im Default und wird nicht automatisch
# aktiviert (PR 26: „No auto-cloud activation").
SMOLIT_TEXT_PROVIDER_CHAIN=abrain

# llamafile_local (optional, env-konfiguriert)
SMOLIT_LLAMAFILE_ENABLED=false
SMOLIT_LLAMAFILE_PATH=
SMOLIT_LLAMAFILE_MODE=on_demand
SMOLIT_LLAMAFILE_PORT=8788
SMOLIT_LLAMAFILE_IDLE_TIMEOUT_SECONDS=300
SMOLIT_LLAMAFILE_STARTUP_TIMEOUT_SECONDS=30
SMOLIT_LLAMAFILE_REQUEST_TIMEOUT_SECONDS=60

# local_http (optional, z. B. llama.cpp-Server auf 127.0.0.1)
SMOLIT_LOCAL_HTTP_ENABLED=false
SMOLIT_LOCAL_HTTP_ENDPOINT=
SMOLIT_LOCAL_HTTP_PROMPT_FIELD=prompt
SMOLIT_LOCAL_HTTP_RESPONSE_FIELD=content
SMOLIT_LOCAL_HTTP_REQUEST_TIMEOUT_SECONDS=60

# cloud_http (opt-in). WICHTIG:
#   * cloud_http wird NICHT automatisch der Chain hinzugefügt.
#   * API-Key wird NIE hier gesetzt. Der Key wird ausschließlich
#     über die Settings-Shell oder IPC (`settings_set_cloud_http_secret`)
#     im Secrets-Store gespeichert. Ein Env-Key wäre eine Regression.
SMOLIT_CLOUD_HTTP_ENABLED=false
SMOLIT_CLOUD_HTTP_ENDPOINT=
SMOLIT_CLOUD_HTTP_MODEL=
SMOLIT_CLOUD_HTTP_REQUEST_TIMEOUT_SECONDS=90

# ------------------------------------------------------------------
# Desktop Interaction Layer — Policy v0 (PR 25)
# ------------------------------------------------------------------
# Baseline-Schutz: require_confirmation=true by default. Produktive
# Builds LASSEN DAS SO. `=0` ist ein reiner Test-Hebel.
SMOLIT_INTERACTION_ENABLED=true
SMOLIT_INTERACTION_BACKEND=command
SMOLIT_INTERACTION_REQUIRE_CONFIRMATION=true

# open_application: real verdrahtet. Command-Template leer → honest
# BackendUnsupported, bis du z. B. `gtk-launch {name}` oder
# `xdg-open {name}` einträgst.
SMOLIT_INTERACTION_ALLOW_OPEN_APP=true
SMOLIT_INTERACTION_OPEN_APP_CMD=

# focus_window: doppeltes Opt-in (PR 23 + PR 25). Default false;
# zusätzlich X11-Template nötig (z. B. `wmctrl -a {name}`). Unter
# Wayland gibt es kein generisches Fokus-Primitiv — leer lassen,
# der Core meldet dann ehrlich BackendUnsupported.
SMOLIT_INTERACTION_ALLOW_FOCUS_WINDOW=false
SMOLIT_INTERACTION_FOCUS_WINDOW_CMD=

# type_text / send_shortcut: `BackendUnsupported` — ein Flag-Flip
# schaltet sie NICHT aktiv (kein Backend vorhanden). Die Flags
# bleiben am Protokoll-Oberfläche stabil; der Executor meldet
# konsequent BackendUnsupported.
SMOLIT_INTERACTION_ALLOW_TYPE_TEXT=false
SMOLIT_INTERACTION_ALLOW_SHORTCUTS=false

# Approval-Wartezeit bis timed_out → action_cancelled.
SMOLIT_APPROVAL_TIMEOUT_SECONDS=20

# ------------------------------------------------------------------
# Audit (PR 19). In-memory Ring-Buffer. Core-Restart leert den Store.
# Scope heute: nur plan_demo_action-Pfad; der reale open_application-
# Flow wird (noch) nicht auditiert.
# ------------------------------------------------------------------
SMOLIT_AUDIT_MAX_EVENTS=100

# ------------------------------------------------------------------
# UI / Overlay / Dev (nur wenn du weißt, was du tust)
# ------------------------------------------------------------------
# Dev-Controls (Demo-Buttons, Audit-Panel). NICHT in Produktion.
# SMOLIT_UI_DEV_CONTROLS=1

# Workflow Visibility Overlay (PR 16) sichtbar per Default.
# SMOLIT_WORKFLOW_OVERLAY=1

# Transparentes Overlay-Fenster (PR-B).
# SMOLIT_UI_OVERLAY=1
# Click-through (setzt SMOLIT_UI_OVERLAY=1 voraus).
# SMOLIT_UI_CLICK_THROUGH=1

# Always-on-top — nur auf echter X11-Session; sonst honest No-op.
# Unter GNOME/Wayland ist AOT bewusst unsupported.
# SMOLIT_UI_ALWAYS_ON_TOP=1

# Diagnose-Probe (einmalig, reversibel).
# SMOLIT_WINDOW_PROBE=1
# SMOLIT_WINDOW_PROBE_REVERT=1

# Konsolidierter Runtime-Report für Bug-Reports.
# SMOLIT_WINDOW_REPORT=1
