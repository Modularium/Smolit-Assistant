ABRAIN_CMD=abrain
LOG_LEVEL=info

SMOLIT_TTS_ENABLED=true
SMOLIT_TTS_CMD=
SMOLIT_STT_ENABLED=true
SMOLIT_STT_CMD=
SMOLIT_AUDIO_AUTO_SPEAK=true
SMOLIT_STT_TIMEOUT_SECONDS=20
SMOLIT_TTS_TIMEOUT_SECONDS=20

SMOLIT_IPC_ENABLED=true
SMOLIT_IPC_BIND=127.0.0.1:8787

# Desktop Interaction Layer (MVP).
# Conservative defaults: layer is enabled, but only open_application is
# allowed; type_text and shortcuts are off until a real backend lands.
# The open-application command template is empty by default, which makes
# the backend honestly report "preconditions not met" until the user
# opts in (e.g. `gtk-launch {name}` or `xdg-open {name}`).
SMOLIT_INTERACTION_ENABLED=true
SMOLIT_INTERACTION_BACKEND=command
SMOLIT_INTERACTION_ALLOW_OPEN_APP=true
SMOLIT_INTERACTION_ALLOW_TYPE_TEXT=false
SMOLIT_INTERACTION_ALLOW_SHORTCUTS=false
SMOLIT_INTERACTION_REQUIRE_CONFIRMATION=true
SMOLIT_INTERACTION_OPEN_APP_CMD=

# Approval / Confirmation flow timeout (seconds). Actions that need a
# user decision (see InteractionConfig.require_confirmation) will be
# cancelled if no approval_response arrives within this window.
SMOLIT_APPROVAL_TIMEOUT_SECONDS=20
